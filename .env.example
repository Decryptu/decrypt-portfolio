UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend, used by the contact forms on /automations and /ai-chat
RESEND_API_KEY=
CONTACT_EMAIL=
# Optional. Defaults to onboarding@resend.dev. Set this to a verified-domain
# sender in production (e.g. noreply@yourdomain.com).
RESEND_FROM=

# Signs the homemade contact-form captcha tokens. Generate with `openssl rand -base64 32`.
# Falls back to an insecure dev value if unset, so local dev works without it.
CONTACT_FORM_SECRET=